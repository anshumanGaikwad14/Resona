extends ../base.pug

block variables 
    - var template = "about"

block content
    .about 
        .about__wrapper
            section.about__hero 
                each images,index in about.data.images
                    figure.about__hero__media 
                        img.about__hero__media__image(alt=images.image.alt src=images.image.url)
                
                h1.about__hero__title=about.data.main_text

            each section in about.data.body 
                if section.slice_type === 'title'
                    section.about__title 
                        .about__title__wrapper 
                            h3.about__title__text=section.primary.text

                if section.slice_type === 'content'
                    section.about__content 
                        .about__content__wrapper 
                            p.about__content__label=section.primary.label

                            .about__content__description!=prismic.asHTML(section.primary.description)

                            figure.about__content__media 
                                img.about__content__media__image(alt=section.primary.image.alt src=section.primary.image.url)

                if section.slice_type === 'highlight'
                    section.about__highlight 
                        .about__highlight__wrapper
                            if section.primary.label
                                p.about__hightlight__label=section.primary.label

                            h2.about__highlight__title=section.primary.title

                            each images in section.items 
                                figure.about__highlight__media 
                                    img.about__highlight__media__image(alt=images.image.alt src=images.image.url)

                if section.slice_type === 'gallery'
                    section.about__gallery 
                        .about__gallery__wrapper 
                            each images in section.items
                                figure.about__gallery__media 
                                    img.about__gallery__media__image(alt=images.image.alt src=images.image.url)


                            

